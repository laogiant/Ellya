# Ellya Skill - .gitignore

# Ignore generated files
outputs/*
!.gitkeep

# Ignore selfie outputs
output/*
styles/*
docs/*

# Ignore Python venv (use uv.lock to reinstall)
.venv/*
__pycache__/

# Ignore sensitive data
*.pem
*.key
*.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
uv.lock

# Publish artifacts and local publish caches
.publish-dist/
.npm-cache/
.uv-cache/
publish.bat
publish/

# Files to be published (excluded from git, copied to publish/)
ANALYSIS_PROMPT.md
README.md
SKILL.md
scripts/
templates/